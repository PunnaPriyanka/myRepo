pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/PunnaPriyanka/myRepo.git'
            }
        }
        stage('Publish') {
           steps{
               publishHTML([
            allowmissing:true,
            alwaysLinktoLastBuild : false,
            KeepAll : false,
            reportDir : '.',
            reportFiles : 'simple.html',
            reportName : 'MY HTML PAGE'
               ])
           }
            
        }
    }
}
